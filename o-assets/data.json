  "roadmap": {
    "title": "Lộ trình cuộc thi",
    "steps": [
      {
        "date": "Tháng 2/2026",
        "event": "Phát động cuộc thi",
        "details": "Ban tổ chức chính thức công bố cuộc thi Olympic Toán Tuổi thơ Online 2026 trên toàn quốc. Thông tin được gửi đến các trường Tiểu học và THCS trên 34 tỉnh thành."
      },
      {
        "date": "Tháng 3/2026",
        "event": "Đăng ký & Luyện thi",
        "details": "Phụ huynh và học sinh đăng ký tài khoản, chọn lớp dự thi. Hệ thống mở đề thi thử miễn phí để làm quen với giao diện và dạng bài."
      },
      {
        "date": "Dự kiến tháng 5/2026",
        "event": "Vòng 1 - Cấp Trường (Thi trực tuyến)",
        "details": "Thí sinh thi trực tuyến tại nhà hoặc trường. 3 đợt cuối tuần (thứ Bảy & Chủ nhật). Mỗi em được thi tối đa 3 lần, hệ thống ghi nhận điểm cao nhất. Tối đa 60% thí sinh điểm cao nhất được vào Vòng 2."
      },
      {
        "date": "Dự kiến tháng 6/2026",
        "event": "Vòng 2 - Cấp Tỉnh (Thi trực tuyến)",
        "details": "Các thí sinh vượt qua Vòng 1 thi trực tuyến. Đề thi nâng cao hơn, yêu cầu tư duy logic và sáng tạo. Tối đa 30% thí sinh điểm cao nhất vào Chung kết."
      },
      {
        "date": "Dự kiến tháng 7/2026",
        "event": "Vòng 3 - Chung kết toàn quốc\n (Thi trực tiếp trên máy tính tại Hà Nội)",
        "details": "Chung kết diễn ra trực tiếp tại Hà Nội. Thí sinh thi 1 lần duy nhất, tranh tài cùng các bạn xuất sắc nhất cả nước. Lễ trao giải trang trọng với nhiều phần thưởng giá trị."
      }
    ]
  },
  "rules": {
    "title": "Thể lệ & Đối tượng",
    "participants": {
      "title": "Đối tượng",
      "content": "Học sinh lớp 4, 5, 6, 7, 8 trên toàn quốc."
    },
    "structure": {
      "title": "Cấu trúc bài thi",
      "content": "15 câu hỏi: 10 câu trắc nghiệm (1 điểm/câu) + 5 câu điền đáp số (2 điểm/câu). Tổng điểm tối đa: 20 điểm."
    },
    "time": {
      "title": "Thời gian làm bài",
      "content": "Lớp 4-7 (30 phút), Lớp 8 (35 phút)."
    },
    "attempts": {
      "title": "Số lần thi",
      "content": "Luyện thi: 3 lần miễn phí. Vòng 1: thi tối đa 3 lần, lấy điểm cao nhất. Vòng 2 và Vòng 3: thi 1 lần duy nhất."
    }
  },
